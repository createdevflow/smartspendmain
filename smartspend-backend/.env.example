# Environment variables for SmartSpend Backend

# ── App Environment ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
ADMIN_PANEL_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# ── Database (PostgreSQL) ────────────────────────────────────────
DB_USER=smartspend
DB_PASSWORD=smartspend_pass
DB_NAME=smartspend
DATABASE_URL=postgresql://smartspend:smartspend_pass@localhost:5432/smartspend?schema=public
DATABASE_POOL_SIZE=10

# ── Cache (Redis) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication & Security ────────────────────────────────────
# Generate keys with: openssl rand -base64 32
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CRITICAL: 64-character hex string (32 bytes) for AES-256-GCM
# Generate with: openssl rand -hex 32
SERVER_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── SMTP Mail (Postal / Mailgun / AWS SES) ────────────────────────
SMTP_HOST=localhost
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME="SmartSpend Support"
MAIL_FROM_ADDRESS="noreply@smartspend.app"

# ── Storage (MinIO / S3) ─────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RECEIPTS=receipts
MINIO_PUBLIC_URL=http://localhost:9000

# ── OTP & Rate Limiting ──────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
THROTTLE_TTL=60
THROTTLE_LIMIT=100
LOGIN_THROTTLE_TTL=900
LOGIN_THROTTLE_LIMIT=5

# ── Super Admin ──────────────────────────────────────────────────
# Setup initial super admin login
SUPER_ADMIN_EMAIL=admin@smartspend.app
SUPER_ADMIN_PASSWORD=SuperSecurePassword!123

# ── Currency Exchange API ────────────────────────────────────────
EXCHANGE_RATE_API=https://api.frankfurter.app
