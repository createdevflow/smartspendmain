// ============================================================
// SmartSpend Backend — Complete Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum AuditAction {
  REGISTER
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGED
  PASSWORD_RESET
  EMAIL_VERIFIED
  PROFILE_UPDATED
  DATA_EXPORT
  DATA_DELETE
  ACCOUNT_SUSPENDED
  ACCOUNT_BANNED
  CASHBOOK_CREATED
  CASHBOOK_DELETED
  TRANSACTION_CREATED
  TRANSACTION_DELETED
  RECEIPT_UPLOADED
  PLAN_CHANGED
  GOAL_CREATED
  BUDGET_CREATED
}

enum NotificationType {
  PUSH
  EMAIL
  IN_APP
}

enum TransactionLabel {
  RECURRING
  HIGH_SPEND
  BUDGET_ALERT
  TAX_DEDUCTIBLE
  GST_APPLIED
  REIMBURSABLE
  NEEDS_REVIEW
  SPLIT_ENTRY
}

enum CashbookMemberRole {
  OWNER
  EDITOR
  VIEWER
}

// ─── USER ───────────────────────────────────────────────────

model User {
  id                String     @id @default(cuid())
  fullName          String
  email             String     @unique
  phone             String?    @unique
  passwordHash      String
  avatar            String?
  role              UserRole   @default(USER)
  status            UserStatus @default(PENDING_VERIFICATION)
  planId            String?
  plan              Plan?      @relation(fields: [planId], references: [id], onDelete: SetNull)
  isEmailVerified   Boolean    @default(false)
  encryptionKeySalt String     // Per-user AES-256 key derivation salt (hex)
  expoPushToken     String?
  defaultCurrency   String     @default("INR")
  timezone          String     @default("Asia/Kolkata")
  language          String     @default("en")
  pushNotifications Boolean    @default(true)
  emailReports      Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  lastLoginAt       DateTime?
  deletedAt         DateTime?

  cashbooks          Cashbook[]
  transactions       Transaction[]
  budgets            Budget[]
  goals              Goal[]
  devices            Device[]
  sessions           Session[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  otpTokens          OtpToken[]
  supportTickets     SupportTicket[]
  merchantMappings   UserMerchantMapping[]
  customCategories   Category[]
  cashbookMembers    CashbookMember[]
  taxExportLogs      TaxExportLog[]

  @@index([email])
  @@index([role, status])
  @@index([planId])
}

// ─── SESSIONS & DEVICES ─────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique // bcrypt-hashed
  deviceName   String?
  platform     String?  // ios | android | web
  ipAddress    String?
  userAgent    String?
  isValid      Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
  @@index([userId, isValid])
}

model Device {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName    String?
  platform      String?
  expoPushToken String?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([userId])
}

// ─── OTP TOKENS ─────────────────────────────────────────────

model OtpToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    // bcrypt-hashed 6-digit OTP
  purpose   String    // email_verify | password_reset
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, purpose])
}

// ─── DYNAMIC PLAN SYSTEM ────────────────────────────────────

model Plan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  tagline     String?
  color       String   @default("#2563EB")
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  priceMonthly Int     @default(0)
  priceYearly  Int     @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  features PlanFeature[]
  users    User[]
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   // "true", "false", or config string
  description String?
  updatedAt   DateTime @updatedAt
}

model Feature {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String
  description  String?
  type         String   // number | boolean | string
  defaultValue String
  unit         String?
  category     String?  // storage | analytics | export | security
  isVisible    Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  planFeatures PlanFeature[]
}

model PlanFeature {
  id        String  @id @default(cuid())
  planId    String
  plan      Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureId String
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  value     String  // "-1" = unlimited, "true"/"false", "10"

  @@unique([planId, featureId])
  @@index([planId])
}

// ─── CASHBOOKS ──────────────────────────────────────────────

model Cashbook {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String    // AES-encrypted
  description    String?   // AES-encrypted
  color          String    @default("#2563EB")
  icon           String    @default("wallet")
  currency       String    @default("INR")
  openingBalance Decimal   @default(0) @db.Decimal(18, 6)
  isArchived     Boolean   @default(false)
  isDefault      Boolean   @default(false)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  transactions Transaction[]
  budgets      Budget[]
  members      CashbookMember[]

  @@index([userId, isArchived])
  @@index([userId, deletedAt])
}

// ─── CATEGORIES ─────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  userId    String?  // null = global/system; non-null = user custom
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  emoji     String
  color     String
  type      String   // income | expense | both
  parentId  String?
  parent    Category?  @relation("SubCategory", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategory")
  isSystem  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  keywords     CategoryKeyword[]
  transactions Transaction[]
  budgets      Budget[]

  @@unique([slug, userId])
  @@index([userId, type])
  @@index([isSystem])
}

model CategoryKeyword {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  keyword    String
  matchType  String   @default("contains") // contains | starts_with | exact
  priority   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([keyword])
  @@index([categoryId])
}

model UserMerchantMapping {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant   String
  categoryId String
  usageCount Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, merchant])
  @@index([userId])
}

// ─── TRANSACTIONS ────────────────────────────────────────────

model Transaction {
  id                  String            @id @default(cuid())
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashbookId          String
  cashbook            Cashbook          @relation(fields: [cashbookId], references: [id], onDelete: Cascade)
  categoryId          String?
  category            Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Amounts
  amount              Decimal           @db.Decimal(18, 6)
  currency            String
  exchangeRate        Decimal?          @db.Decimal(18, 8)
  amountInBookCurrency Decimal?         @db.Decimal(18, 6)

  // Encrypted sensitive fields (stored as AES-GCM output)
  encNotes            String?
  encMerchant         String?

  type                TransactionType
  paymentMethod       String?           // cash | upi | card | netbanking | cheque | crypto | wallet
  date                DateTime
  valueDate           DateTime?

  labels              TransactionLabel[] @default([])
  tags                String[]           @default([])

  // GST
  isGstApplied        Boolean           @default(false)
  gstRate             Decimal?          @db.Decimal(5, 2)
  cgst                Decimal?          @db.Decimal(18, 6)
  sgst                Decimal?          @db.Decimal(18, 6)
  igst                Decimal?          @db.Decimal(18, 6)

  // Receipt
  receiptKey          String?
  receiptUrl          String?
  warrantyUntil       DateTime?

  // Recurring
  isRecurring         Boolean           @default(false)
  recurringId         String?
  recurring           RecurringTransaction? @relation(fields: [recurringId], references: [id], onDelete: SetNull)

  // Offline sync
  localId             String?           // client-generated dedup key
  syncedAt            DateTime?

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  splits TransactionSplit[]

  @@index([userId, date])
  @@index([cashbookId, date])
  @@index([userId, categoryId])
  @@index([userId, type, date])
  @@index([localId])
  @@index([userId, deletedAt])
}

model TransactionSplit {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  categoryId    String?
  amount        Decimal     @db.Decimal(18, 6)
  note          String?
  createdAt     DateTime    @default(now())

  @@index([transactionId])
}

// ─── RECURRING TRANSACTIONS ──────────────────────────────────

model RecurringTransaction {
  id               String          @id @default(cuid())
  userId           String
  cashbookId       String
  categoryId       String?
  name             String          // AES-encrypted
  amount           Decimal         @db.Decimal(18, 6)
  currency         String          @default("INR")
  type             TransactionType
  paymentMethod    String?
  frequency        String          // daily | weekly | biweekly | monthly | quarterly | yearly
  dayOfMonth       Int?
  dayOfWeek        Int?
  startDate        DateTime
  endDate          DateTime?
  nextDueAt        DateTime
  lastProcessedAt  DateTime?
  isActive         Boolean         @default(true)
  autoCreate       Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  generatedTransactions Transaction[]

  @@index([userId, isActive])
  @@index([nextDueAt, isActive])
}

// ─── BUDGETS ─────────────────────────────────────────────────

model Budget {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashbookId  String?
  cashbook    Cashbook?    @relation(fields: [cashbookId], references: [id], onDelete: SetNull)
  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name        String
  amount      Decimal      @db.Decimal(18, 6)
  currency    String       @default("INR")
  period      BudgetPeriod @default(MONTHLY)
  startDate   DateTime
  endDate     DateTime?
  rollover    Boolean      @default(false)
  alertAt50   Boolean      @default(true)
  alertAt80   Boolean      @default(true)
  alertAt100  Boolean      @default(true)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, isActive])
  @@index([userId, categoryId])
}

// ─── GOALS ───────────────────────────────────────────────────

model Goal {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String     // AES-encrypted
  description      String?    // AES-encrypted
  emoji            String?    @default("🎯")
  targetAmount     Decimal    @db.Decimal(18, 6)
  currentAmount    Decimal    @default(0) @db.Decimal(18, 6)
  currency         String     @default("INR")
  deadline         DateTime?
  status           GoalStatus @default(ACTIVE)
  linkedCashbookId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  contributions GoalContribution[]

  @@index([userId, status])
}

model GoalContribution {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(18, 6)
  note      String?
  createdAt DateTime @default(now())

  @@index([goalId])
}

// ─── EXCHANGE RATES CACHE ────────────────────────────────────

model ExchangeRate {
  id        String   @id @default(cuid())
  base      String
  target    String
  rate      Decimal  @db.Decimal(18, 8)
  fetchedAt DateTime @default(now())

  @@unique([base, target])
  @@index([fetchedAt])
}

// ─── NOTIFICATIONS ───────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  actionUrl String?
  isRead    Boolean          @default(false)
  sentAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─── AUDIT LOGS ──────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    AuditAction
  entity    String?
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([userId, action])
  @@index([createdAt])
}

// ─── SUPPORT ─────────────────────────────────────────────────

model SupportTicket {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    String
  message    String
  type       String   @default("contact_us") // contact_us | bug_report
  status     String   @default("open")
  priority   String   @default("normal")
  attachmentUrl String?
  resolvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  replies TicketReply[]

  @@index([userId, status])
  @@index([status, priority])
}

model TicketReply {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  message   String
  isAdmin   Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

// ─── APP CONFIG ──────────────────────────────────────────────

model AppConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  isPublic    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// ─── ANNOUNCEMENTS ───────────────────────────────────────────

model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String
  type        String   @default("info")
  targetRoles String[] @default([])
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── SHARED CASHBOOKS ─────────────────────────────────────────

model CashbookMember {
  id          String             @id @default(cuid())
  cashbookId  String
  cashbook    Cashbook           @relation(fields: [cashbookId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String
  role        CashbookMemberRole @default(VIEWER)
  status      String             @default("pending") // pending | accepted | rejected
  inviteToken String?            @unique
  invitedAt   DateTime           @default(now())
  acceptedAt  DateTime?

  @@unique([cashbookId, email])
  @@index([cashbookId])
  @@index([userId])
  @@index([inviteToken])
}

// ─── TAX EXPORT LOGS ─────────────────────────────────────────

model TaxExportLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year        Int
  txCount     Int
  totalAmount Decimal  @db.Decimal(18, 6)
  exportedAt  DateTime @default(now())

  @@index([userId])
  @@index([exportedAt])
}
