// ============================================================
// SmartSpend Backend — Complete Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum AuditAction {
  REGISTER
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGED
  PASSWORD_RESET
  EMAIL_VERIFIED
  PROFILE_UPDATED
  DATA_EXPORT
  DATA_DELETE
  ACCOUNT_SUSPENDED
  ACCOUNT_BANNED
  CASHBOOK_CREATED
  CASHBOOK_DELETED
  TRANSACTION_CREATED
  TRANSACTION_DELETED
  RECEIPT_UPLOADED
  PLAN_CHANGED
  GOAL_CREATED
  BUDGET_CREATED
}

enum NotificationType {
  PUSH
  EMAIL
  IN_APP
}

enum TransactionLabel {
  RECURRING
  HIGH_SPEND
  BUDGET_ALERT
  TAX_DEDUCTIBLE
  GST_APPLIED
  REIMBURSABLE
  NEEDS_REVIEW
  SPLIT_ENTRY
}

enum CashbookMemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum ScheduleRepeat {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ScheduleStatus {
  PENDING
  SENT
  FAILED
  PAUSED
  CANCELLED
}

enum NotificationCategory {
  BUDGET
  GOAL
  TRANSACTION
  REPORT
  SCHEDULER
  SECURITY
  SYSTEM
  WEALTH
  ADMIN
}

enum AdminNotifType {
  ANNOUNCEMENT
  FEATURE_UPDATE
  MAINTENANCE
  SECURITY
  OFFER
  PROMOTIONAL
  REMINDER
  INFO
}

enum AdminNotifAudience {
  ALL
  FREE_USERS
  PREMIUM_USERS
  SELECTED
  ANDROID
  IOS
}

enum AdminNotifStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

// ─── USER ───────────────────────────────────────────────────

model User {
  id                String     @id @default(cuid())
  fullName          String
  email             String     @unique
  phone             String?    @unique
  passwordHash      String
  avatar            String?
  role              UserRole   @default(USER)
  status            UserStatus @default(PENDING_VERIFICATION)
  planId            String?
  plan              Plan?      @relation(fields: [planId], references: [id], onDelete: SetNull)
  isEmailVerified   Boolean    @default(false)
  encryptionKeySalt String // Per-user AES-256 key derivation salt (hex)
  expoPushToken     String?
  defaultCurrency   String     @default("INR")
  timezone          String     @default("Asia/Kolkata")
  language          String     @default("en")
  pushNotifications Boolean    @default(true)
  emailReports      Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  lastLoginAt       DateTime?
  deletedAt         DateTime?
  trialExpiresAt    DateTime?

  cashbooks        Cashbook[]
  transactions     Transaction[]
  budgets          Budget[]
  goals            Goal[]
  devices          Device[]
  sessions         Session[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  otpTokens        OtpToken[]
  supportTickets   SupportTicket[]
  merchantMappings UserMerchantMapping[]
  customCategories Category[]
  cashbookMembers  CashbookMember[]
  taxExportLogs    TaxExportLog[]

  // Chat relations
  contactsFrom          ChatContact[]          @relation("ContactFrom")
  contactsTo            ChatContact[]          @relation("ContactTo")
  chatMemberships       ChatMember[]           @relation("ChatMemberships")
  sentMessages          ChatMessage[]          @relation("SentMessages")
  messageReactions      ChatMessageReaction[]  @relation("MessageReactions")
  messageReads          ChatMessageRead[]      @relation("MessageReads")
  starredMessages       StarredMessage[]       @relation("StarredMessages")
  scheduledChatMessages ScheduledChatMessage[] @relation("ScheduledMessages")
  messageReminders      MessageReminder[]      @relation("MessageReminders")

  // Wealth Hub relations
  watchlists        Watchlist[]
  portfolioHoldings PortfolioHolding[]
  priceAlerts       PriceAlert[]
  savedArticles     SavedArticle[]
  sipEntries        SIPEntry[]
  SubscriptionOrder SubscriptionOrder[]

  // Communication Center
  scheduledEmails        ScheduledEmail[]
  scheduledMessages      ScheduledMessage[]
  notificationPreference NotificationPreference?
  adminNotifRecipients   AdminNotifRecipient[]

  userNotes   UserNote[]   @relation("UserNotes")
  adminNotes  UserNote[]   @relation("AdminNotes")
  blogs       Blog[]
  mediaAssets MediaAsset[]

  // AI Integration
  aiCredit      UserAiCredit?
  aiRequestLogs AiRequestLog[]

  @@index([email])
  @@index([role, status])
  @@index([planId])
}

// ─── SESSIONS & DEVICES ─────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique // bcrypt-hashed
  deviceName   String?
  platform     String? // ios | android | web
  ipAddress    String?
  userAgent    String?
  isValid      Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
  @@index([userId, isValid])
}

model Device {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName    String?
  platform      String?
  expoPushToken String?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([userId])
}

// ─── OTP TOKENS ─────────────────────────────────────────────

model OtpToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String // bcrypt-hashed 6-digit OTP
  purpose   String // email_verify | password_reset
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, purpose])
}

// ─── DYNAMIC PLAN SYSTEM ────────────────────────────────────

model Plan {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  tagline      String?
  color        String   @default("#2563EB")
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)
  priceWeekly  Int      @default(0)
  priceMonthly Int      @default(0)
  priceYearly  Int      @default(0)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  features          PlanFeature[]
  users             User[]
  SubscriptionOrder SubscriptionOrder[]
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String // "true", "false", or config string
  description String?
  updatedAt   DateTime @updatedAt
}

model Feature {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String
  description  String?
  type         String // number | boolean | string
  defaultValue String
  unit         String?
  category     String? // storage | analytics | export | security
  isVisible    Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  planFeatures PlanFeature[]
}

model PlanFeature {
  id        String  @id @default(cuid())
  planId    String
  plan      Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureId String
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  value     String // "-1" = unlimited, "true"/"false", "10"

  @@unique([planId, featureId])
  @@index([planId])
}

// ─── CASHBOOKS ──────────────────────────────────────────────

model Cashbook {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String // AES-encrypted
  description    String? // AES-encrypted
  color          String    @default("#2563EB")
  icon           String    @default("wallet")
  currency       String    @default("INR")
  openingBalance Decimal   @default(0) @db.Decimal(18, 6)
  isArchived     Boolean   @default(false)
  isDefault      Boolean   @default(false)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  transactions Transaction[]
  budgets      Budget[]
  members      CashbookMember[]

  @@index([userId, isArchived])
  @@index([userId, deletedAt])
}

// ─── CATEGORIES ─────────────────────────────────────────────

model Category {
  id        String     @id @default(cuid())
  userId    String? // null = global/system; non-null = user custom
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  emoji     String
  color     String
  type      String // income | expense | both
  parentId  String?
  parent    Category?  @relation("SubCategory", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategory")
  isSystem  Boolean    @default(false)
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())

  keywords     CategoryKeyword[]
  transactions Transaction[]
  budgets      Budget[]

  @@unique([slug, userId])
  @@index([userId, type])
  @@index([isSystem])
}

model CategoryKeyword {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  keyword    String
  matchType  String   @default("contains") // contains | starts_with | exact
  priority   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([keyword])
  @@index([categoryId])
}

model UserMerchantMapping {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchant   String
  categoryId String
  usageCount Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, merchant])
  @@index([userId])
}

// ─── TRANSACTIONS ────────────────────────────────────────────

model Transaction {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashbookId String
  cashbook   Cashbook  @relation(fields: [cashbookId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // Amounts
  amount               Decimal  @db.Decimal(18, 6)
  currency             String
  exchangeRate         Decimal? @db.Decimal(18, 8)
  amountInBookCurrency Decimal? @db.Decimal(18, 6)

  // Encrypted sensitive fields (stored as AES-GCM output)
  encNotes    String?
  encMerchant String?

  type          TransactionType
  paymentMethod String? // cash | upi | card | netbanking | cheque | crypto | wallet
  date          DateTime
  valueDate     DateTime?

  labels TransactionLabel[] @default([])
  tags   String[]           @default([])

  // GST
  isGstApplied Boolean  @default(false)
  gstRate      Decimal? @db.Decimal(5, 2)
  cgst         Decimal? @db.Decimal(18, 6)
  sgst         Decimal? @db.Decimal(18, 6)
  igst         Decimal? @db.Decimal(18, 6)

  // Receipt
  receiptKey    String?
  receiptUrl    String?
  warrantyUntil DateTime?

  // Recurring
  isRecurring Boolean               @default(false)
  recurringId String?
  recurring   RecurringTransaction? @relation(fields: [recurringId], references: [id], onDelete: SetNull)

  // Offline sync
  localId  String? // client-generated dedup key
  syncedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  splits TransactionSplit[]

  @@index([userId, date])
  @@index([cashbookId, date])
  @@index([userId, categoryId])
  @@index([userId, type, date])
  @@index([localId])
  @@index([userId, deletedAt])
  @@index([userId, deletedAt, date])
  @@index([cashbookId, deletedAt, date])
}

model TransactionSplit {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  categoryId    String?
  amount        Decimal     @db.Decimal(18, 6)
  note          String?
  createdAt     DateTime    @default(now())

  @@index([transactionId])
}

// ─── RECURRING TRANSACTIONS ──────────────────────────────────

model RecurringTransaction {
  id              String          @id @default(cuid())
  userId          String
  cashbookId      String
  categoryId      String?
  name            String // AES-encrypted
  amount          Decimal         @db.Decimal(18, 6)
  currency        String          @default("INR")
  type            TransactionType
  paymentMethod   String?
  frequency       String // daily | weekly | biweekly | monthly | quarterly | yearly
  dayOfMonth      Int?
  dayOfWeek       Int?
  startDate       DateTime
  endDate         DateTime?
  nextDueAt       DateTime
  lastProcessedAt DateTime?
  isActive        Boolean         @default(true)
  autoCreate      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  generatedTransactions Transaction[]

  @@index([userId, isActive])
  @@index([nextDueAt, isActive])
}

// ─── BUDGETS ─────────────────────────────────────────────────

model Budget {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashbookId String?
  cashbook   Cashbook?    @relation(fields: [cashbookId], references: [id], onDelete: SetNull)
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name       String
  amount     Decimal      @db.Decimal(18, 6)
  currency   String       @default("INR")
  period     BudgetPeriod @default(MONTHLY)
  startDate  DateTime
  endDate    DateTime?
  rollover   Boolean      @default(false)
  alertAt50  Boolean      @default(true)
  alertAt80  Boolean      @default(true)
  alertAt100 Boolean      @default(true)
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([userId, isActive])
  @@index([userId, categoryId])
}

// ─── GOALS ───────────────────────────────────────────────────

model Goal {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String // AES-encrypted
  description      String? // AES-encrypted
  emoji            String?    @default("🎯")
  targetAmount     Decimal    @db.Decimal(18, 6)
  currentAmount    Decimal    @default(0) @db.Decimal(18, 6)
  currency         String     @default("INR")
  deadline         DateTime?
  status           GoalStatus @default(ACTIVE)
  linkedCashbookId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  contributions GoalContribution[]

  @@index([userId, status])
}

model GoalContribution {
  id        String   @id @default(cuid())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(18, 6)
  note      String?
  createdAt DateTime @default(now())

  @@index([goalId])
}

// ─── EXCHANGE RATES CACHE ────────────────────────────────────

model ExchangeRate {
  id        String   @id @default(cuid())
  base      String
  target    String
  rate      Decimal  @db.Decimal(18, 8)
  fetchedAt DateTime @default(now())

  @@unique([base, target])
  @@index([fetchedAt])
}

// ─── NOTIFICATIONS ───────────────────────────────────────────

model Notification {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         NotificationType
  category     NotificationCategory @default(SYSTEM)
  title        String
  body         String
  data         Json?
  actionUrl    String?
  imageUrl     String?
  actionButton String?
  isRead       Boolean              @default(false)
  isPinned     Boolean              @default(false)
  isArchived   Boolean              @default(false)
  sentAt       DateTime?
  createdAt    DateTime             @default(now())

  @@index([userId, isRead])
  @@index([userId, category])
  @@index([userId, createdAt])
  @@index([userId, isArchived])
}

// ─── AUDIT LOGS ──────────────────────────────────────────────

model UserNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserNotes", fields: [userId], references: [id], onDelete: Cascade)
  adminId   String
  admin     User     @relation("AdminNotes", fields: [adminId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    AuditAction
  entity    String?
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([userId, action])
  @@index([createdAt])
}

// ─── SUPPORT ─────────────────────────────────────────────────

model SupportTicket {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       String
  message       String
  type          String    @default("contact_us") // contact_us | bug_report
  status        String    @default("open")
  priority      String    @default("normal")
  attachmentUrl String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  replies TicketReply[]

  @@index([userId, status])
  @@index([status, priority])
}

model TicketReply {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  message   String
  isAdmin   Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

// ─── APP CONFIG ──────────────────────────────────────────────

model AppConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  isPublic    Boolean  @default(false)
  teaseMode   Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// ─── ANNOUNCEMENTS ───────────────────────────────────────────

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  type        String    @default("info")
  targetRoles String[]  @default([])
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── SHARED CASHBOOKS ─────────────────────────────────────────

model CashbookMember {
  id          String             @id @default(cuid())
  cashbookId  String
  cashbook    Cashbook           @relation(fields: [cashbookId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String
  role        CashbookMemberRole @default(VIEWER)
  status      String             @default("pending") // pending | accepted | rejected
  inviteToken String?            @unique
  invitedAt   DateTime           @default(now())
  acceptedAt  DateTime?

  @@unique([cashbookId, email])
  @@index([cashbookId])
  @@index([userId])
  @@index([inviteToken])
}

// ─── TAX EXPORT LOGS ─────────────────────────────────────────

model TaxExportLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year        Int
  txCount     Int
  totalAmount Decimal  @db.Decimal(18, 6)
  exportedAt  DateTime @default(now())

  @@index([userId])
  @@index([exportedAt])
}

// ─── MESSAGING SYSTEM ────────────────────────────────────────

enum ContactStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  VOICE
  TRANSACTION
  RECEIPT
  LOCATION
  CONTACT_CARD
  SYSTEM
  BUDGET
  GOAL
  REPORT
  INVOICE
  PASSBOOK
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
  DELETED
}

enum ConversationType {
  DIRECT
  GROUP
  CASHBOOK_GROUP
  NOTES_SELF
}

enum MessageRepeatType {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

enum ChatNotifPref {
  EVERYTHING
  MENTION_ONLY
  MUTE
  SILENT
}

enum ChatCategory {
  PERSONAL
  FAMILY
  BUSINESS
}

model ChatContact {
  id         String        @id @default(cuid())
  fromUserId String
  fromUser   User          @relation("ContactFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User          @relation("ContactTo", fields: [toUserId], references: [id], onDelete: Cascade)
  status     ContactStatus @default(PENDING)
  blockedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
  @@index([fromUserId, status])
}

model ChatConversation {
  id              String           @id @default(cuid())
  type            ConversationType @default(DIRECT)
  name            String? // for group chats
  avatar          String?
  cashbookId      String? // for CASHBOOK_GROUP type
  lastMessageAt   DateTime?
  lastMessageText String? // preview
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  members  ChatMember[]
  messages ChatMessage[]

  @@index([lastMessageAt])
}

model ChatMember {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User             @relation("ChatMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role           String           @default("member") // admin | member
  isMuted        Boolean          @default(false)
  isPinned       Boolean          @default(false)
  isArchived     Boolean          @default(false)
  lastReadAt     DateTime?
  notifPref      ChatNotifPref    @default(EVERYTHING)
  category       ChatCategory     @default(PERSONAL)
  joinedAt       DateTime         @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model ChatMessage {
  id              String           @id @default(cuid())
  conversationId  String
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User             @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  type            MessageType      @default(TEXT)
  content         String? // AES-encrypted text content
  mediaUrl        String? // image/document/voice URL
  metadata        Json? // for transaction cards, location, etc.
  replyToId       String?
  replyTo         ChatMessage?     @relation("Replies", fields: [replyToId], references: [id])
  replies         ChatMessage[]    @relation("Replies")
  forwardedFromId String? // original message id if forwarded
  status          MessageStatus    @default(SENT)
  isEdited        Boolean          @default(false)
  editedAt        DateTime?
  deletedAt       DateTime?
  isPinned        Boolean          @default(false)
  createdAt       DateTime         @default(now())

  reactions ChatMessageReaction[]
  readBy    ChatMessageRead[]
  starredBy StarredMessage[]
  reminders MessageReminder[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([conversationId, deletedAt, createdAt])
}

model ChatMessageReaction {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("MessageReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ChatMessageRead {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("MessageReads", fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime    @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
}

model StarredMessage {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation("StarredMessages", fields: [userId], references: [id], onDelete: Cascade)
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, messageId])
  @@index([userId])
}

model ScheduledChatMessage {
  id             String            @id @default(cuid())
  senderId       String
  sender         User              @relation("ScheduledMessages", fields: [senderId], references: [id], onDelete: Cascade)
  conversationId String
  type           MessageType       @default(TEXT)
  content        String?
  mediaUrl       String?
  metadata       Json?
  scheduledAt    DateTime
  repeatType     MessageRepeatType @default(ONCE)
  isSent         Boolean           @default(false)
  createdAt      DateTime          @default(now())

  @@index([scheduledAt, isSent])
  @@index([senderId])
}

model MessageReminder {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation("MessageReminders", fields: [userId], references: [id], onDelete: Cascade)
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  remindAt  DateTime
  note      String?
  isSent    Boolean     @default(false)
  createdAt DateTime    @default(now())

  @@index([remindAt, isSent])
  @@index([userId])
}

// --- WEALTH HUB ----------------------------------------------

enum WealthAssetType {
  CRYPTO
  GOLD
  SILVER
  PLATINUM
  STOCK
  FOREX
  MUTUAL_FUND
}

enum AlertDirection {
  ABOVE
  BELOW
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#2563EB")
  icon      String   @default("star")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items WatchlistItem[]

  @@index([userId])
}

model WatchlistItem {
  id          String          @id @default(cuid())
  watchlistId String
  watchlist   Watchlist       @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  assetType   WealthAssetType
  symbol      String
  displayName String
  note        String?
  alertPrice  Float?
  alertAbove  Boolean         @default(true)
  createdAt   DateTime        @default(now())

  @@unique([watchlistId, symbol])
  @@index([watchlistId])
}

model PortfolioHolding {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetType   WealthAssetType
  symbol      String
  displayName String
  quantity    Float
  buyPrice    Float
  buyDate     DateTime?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([userId, assetType])
}

model PriceAlert {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetType   WealthAssetType
  symbol      String
  displayName String
  targetPrice Float
  direction   AlertDirection
  triggered   Boolean         @default(false)
  triggeredAt DateTime?
  createdAt   DateTime        @default(now())

  @@index([userId, triggered])
  @@index([triggered])
}

model SavedArticle {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url      String
  title    String
  summary  String?
  imageUrl String?
  source   String?
  category String?
  savedAt  DateTime @default(now())

  @@unique([userId, url])
  @@index([userId])
}

model SIPEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fundName   String
  amfiCode   String?
  monthlyAmt Float
  startDate  DateTime
  units      Float    @default(0)
  avgNav     Float    @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

// ─── PAYMENTS & SUBSCRIPTIONS ───────────────────────────────

model SubscriptionOrder {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id])
  orderId   String   @unique
  paymentId String?
  signature String?
  amount    Float
  currency  String   @default("INR")
  status    String   @default("created") // created | paid | failed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([orderId])
}

// ─── COMMUNICATION CENTER ────────────────────────────────────

model ScheduledEmail {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients  String[] // email addresses
  subject     String
  body        String
  attachments Json? // [{name, url, type}]
  emailType   String         @default("custom") // custom | receipt | invoice | report | export
  scheduledAt DateTime
  timezone    String         @default("Asia/Kolkata")
  repeat      ScheduleRepeat @default(ONE_TIME)
  status      ScheduleStatus @default(PENDING)
  lastSentAt  DateTime?
  nextRunAt   DateTime?
  sentCount   Int            @default(0)
  failCount   Int            @default(0)
  lastError   String?
  metadata    Json? // source data (cashbookId, reportType, etc.)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  deliveryLogs EmailDeliveryLog[]

  @@index([userId, status])
  @@index([status, scheduledAt])
  @@index([nextRunAt, status])
}

model EmailDeliveryLog {
  id               String         @id @default(cuid())
  scheduledEmailId String
  scheduledEmail   ScheduledEmail @relation(fields: [scheduledEmailId], references: [id], onDelete: Cascade)
  status           String // sent | failed
  recipients       String[]
  error            String?
  sentAt           DateTime       @default(now())

  @@index([scheduledEmailId])
}

model ScheduledMessage {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId String
  content        String
  messageType    String         @default("TEXT") // TEXT | RECEIPT | TRANSACTION | INVOICE | REMINDER
  attachmentData Json? // shared data (transactionId, invoiceId, etc.)
  scheduledAt    DateTime
  repeat         ScheduleRepeat @default(ONE_TIME)
  status         ScheduleStatus @default(PENDING)
  lastSentAt     DateTime?
  nextRunAt      DateTime?
  sentCount      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId, status])
  @@index([status, scheduledAt])
  @@index([nextRunAt, status])
  @@index([conversationId])
}

model AdminNotification {
  id              String             @id @default(cuid())
  title           String
  subtitle        String?
  body            String
  bannerImage     String?
  iconName        String?
  buttonText      String?
  actionUrl       String?
  notifType       AdminNotifType     @default(ANNOUNCEMENT)
  audience        AdminNotifAudience @default(ALL)
  selectedUserIds String[]
  channelInApp    Boolean            @default(true)
  channelPush     Boolean            @default(false)
  status          AdminNotifStatus   @default(DRAFT)
  scheduledAt     DateTime?
  sentAt          DateTime?
  sentCount       Int                @default(0)
  createdById     String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  recipients AdminNotifRecipient[]

  @@index([status])
  @@index([scheduledAt, status])
}

model AdminNotifRecipient {
  id                  String            @id @default(cuid())
  adminNotificationId String
  adminNotification   AdminNotification @relation(fields: [adminNotificationId], references: [id], onDelete: Cascade)
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveredAt         DateTime?
  readAt              DateTime?
  clickedAt           DateTime?
  createdAt           DateTime          @default(now())

  @@unique([adminNotificationId, userId])
  @@index([userId])
  @@index([adminNotificationId])
}

model NotificationPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetAlerts      Boolean  @default(true)
  goalAlerts        Boolean  @default(true)
  transactionAlerts Boolean  @default(true)
  reportAlerts      Boolean  @default(true)
  schedulerAlerts   Boolean  @default(true)
  securityAlerts    Boolean  @default(true)
  systemAlerts      Boolean  @default(true)
  wealthAlerts      Boolean  @default(true)
  adminAlerts       Boolean  @default(true)
  pushEnabled       Boolean  @default(true)
  emailEnabled      Boolean  @default(true)
  inAppEnabled      Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

// ─── BLOG ────────────────────────────────────────────────────

model Blog {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String?       @db.Text
  content        Json // Rich editor blocks as JSON array
  coverImage     String?
  ogImage        String?
  seoTitle       String?
  seoDescription String?       @db.Text
  focusKeywords  String?
  canonicalUrl   String?
  metaRobots     String        @default("index,follow")
  status         BlogStatus    @default(DRAFT)
  featured       Boolean       @default(false)
  readingTime    Int? // estimated minutes
  publishedAt    DateTime?
  scheduledAt    DateTime?
  authorId       String
  author         User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId     String?
  category       BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags           BlogTag[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([slug])
  @@index([authorId])
}

model BlogCategory {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  color String @default("#2563EB")
  blogs Blog[]

  @@index([slug])
}

model BlogTag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  blogs Blog[]

  @@index([slug])
}

model MediaAsset {
  id              String   @id @default(cuid())
  filePath        String   @unique
  storageKey      String   @unique
  url             String
  hash            String
  size            Int
  compressedSize  Int?
  originalSize    Int?
  type            String
  dimensions      Json?
  metadata        Json?
  ownerId         String?
  owner           User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  module          String
  uploadDate      DateTime @default(now())
  status          String   @default("ACTIVE")
  downloads       Int      @default(0)
  usageCount      Int      @default(1)
  storageLocation String   @default("MINIO")

  @@index([hash, status])
  @@index([module, status])
  @@index([ownerId])
  @@index([uploadDate])
}

// --- AI INTEGRATION -----------------------------------------

model UserAiCredit {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Int      @default(0) // Current available credits
  monthlyUsage  Int      @default(0) // Credits used this month
  lifetimeUsage Int      @default(0) // Total credits ever used
  lastResetDate DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AiRequestLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature        String // e.g., 'RECEIPT_SCAN', 'FINANCIAL_INSIGHT'
  modelUsed      String // e.g., 'gemini-2.5-flash'
  tokensConsumed Int      @default(0)
  creditsCost    Int      @default(0)
  durationMs     Int      @default(0)
  status         String // 'SUCCESS', 'FAILED', 'RATE_LIMITED'
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
}
